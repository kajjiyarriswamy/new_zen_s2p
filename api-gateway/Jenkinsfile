pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build API Gateway') {
            steps {
                dir('api-gateway') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('api-gateway') {
                    sh 'docker build -t api-gateway:latest .'
                }
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                docker stop api-gateway || true
                docker rm api-gateway || true

                docker run -d \
                  --name api-gateway \
                  -p 8082:8083 \
                  api-gateway:latest
                '''
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }
}
